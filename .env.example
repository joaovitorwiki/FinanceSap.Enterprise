# =============================================================================
# .env.example — FinanceSap.Enterprise
# Copie este arquivo para .env e preencha com os valores reais.
# O arquivo .env NUNCA deve ser commitado (está no .gitignore).
# =============================================================================

# Banco de dados MySQL
MYSQL_ROOT_PASSWORD=<senha-forte-aqui>
MYSQL_DATABASE=financesap

# Connection string da aplicação (sobrescreve appsettings.json)
ConnectionStrings__DefaultConnection=Server=localhost;Port=3306;Database=financesap;Uid=root;Pwd=<senha-forte-aqui>;
